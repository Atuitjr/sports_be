# Server
PORT=3000
BASE_PATH=/api

# football-data.org
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
API_HEADER_NAME=X-Auth-Token
API_SECRET_KEY=your_api_key_here
API_TIMEOUT=5000

# Redis (get this from Upstash after creating a database)
REDIS_URL=redis://default:your_password@your_host:port

# Logging: error | warn | info | debug
LOG_LEVEL=info
